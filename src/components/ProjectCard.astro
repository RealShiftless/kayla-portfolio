---
import { formatProjectStartShort } from "../lib/projects";

type Project = {
  data: {
    title: string;
    slug: string;
    type: string;
    status: string;
    summary: string;
    stack: string[];
    startDate?: string;
    github?: string;
  };
};

const { project } = Astro.props as { project: Project };
const startDate = formatProjectStartShort(project.data.startDate);
---

<article class="project-card">
  <div class="project-meta">
    <span>{project.data.type}</span>
    <span>{project.data.status}</span>
  </div>
  <h3><a href={`projects/${project.data.slug}.html`}>{project.data.title}</a></h3>
  <p>{project.data.summary}</p>
  <div class="tags">
    {project.data.stack.map((tag) => <span class="tag">{tag}</span>)}
  </div>
  <div class="project-card-footer">
    {startDate && <div class="project-start">Started {startDate}</div>}
    <div class="project-actions">
      {project.data.github && (
        <a class="github-link" href={project.data.github} target="_blank" rel="noreferrer">
          <span>GitHub</span>
          <img class="project-action-icon" src="img/icons/github.svg" alt="" aria-hidden="true">
        </a>
      )}
    </div>
  </div>
</article>
