---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatProjectStartDate } from "../../lib/projects";

export async function getStaticPaths() {
  const projects = await getCollection("projects");

  return projects.map((project) => ({
    params: { slug: project.data.slug },
    props: { project }
  }));
}

const { project } = Astro.props;
const hasDemoLink = Boolean(project.data.demo);
const hasGithubLink = Boolean(project.data.github);
const sectionClasses = ["section-mint", "section-lilac", "section-rose", "section-blue"];
const hasProcessionModelViewer = project.data.slug === "procession";
const startDate = formatProjectStartDate(project.data.startDate);

function escapeHtml(value: string) {
  return value
    .replaceAll("&", "&amp;")
    .replaceAll("<", "&lt;")
    .replaceAll(">", "&gt;")
    .replaceAll('"', "&quot;");
}

function inlineMarkdown(value: string) {
  return escapeHtml(value).replace(/`([^`]+)`/g, "<code>$1</code>");
}

function parseProjectSections(body = "") {
  const lines = body.split(/\r?\n/);
  const sections: Array<{ title: string; blocks: Array<{ type: "p"; text: string } | { type: "ul"; items: string[] }> }> = [];
  let current: (typeof sections)[number] | null = null;
  let paragraph: string[] = [];
  let list: string[] = [];

  function ensureSection() {
    if (!current) {
      current = { title: "Notes", blocks: [] };
      sections.push(current);
    }
    return current;
  }

  function flushParagraph() {
    if (paragraph.length > 0) {
      ensureSection().blocks.push({ type: "p", text: paragraph.join(" ") });
      paragraph = [];
    }
  }

  function flushList() {
    if (list.length > 0) {
      ensureSection().blocks.push({ type: "ul", items: list });
      list = [];
    }
  }

  for (const rawLine of lines) {
    const line = rawLine.trim();

    if (line.startsWith("## ")) {
      flushParagraph();
      flushList();
      current = { title: line.slice(3).trim(), blocks: [] };
      sections.push(current);
      continue;
    }

    if (!line) {
      flushParagraph();
      flushList();
      continue;
    }

    if (line.startsWith("- ")) {
      flushParagraph();
      list.push(line.slice(2).trim());
      continue;
    }

    flushList();
    paragraph.push(line);
  }

  flushParagraph();
  flushList();
  return sections;
}

const sections = parseProjectSections(project.body);
---

<BaseLayout
  title={`${project.data.title} - Kayla Moulding`}
  description={project.data.summary}
  assetPrefix="../"
  currentProject={project.data.slug}
>
  <main>
    <section class="section section-blue project-page">
      <nav class="breadcrumb" aria-label="Project location">
        <a href="../index.html#projects">projects</a>
        <span>/</span>
        {project.data.parent && <><span>{project.data.parent}</span><span>/</span></>}
        <span class="breadcrumb-current">{project.data.slug}</span>
      </nav>
      <div class="wrap project-hero">
        <div>
          <p class="eyebrow">Project write-up</p>
          <h1>{project.data.title}</h1>
          <p class="lead">{project.data.summary}</p>
          <div class="hero-actions">
            {hasDemoLink && <a class="button" href={project.data.demo}>Demo</a>}
            <a class="button button-secondary" href="../index.html#projects">All projects</a>
            {hasGithubLink && (
              <a class="button button-secondary button-icon-link" href={project.data.github} target="_blank" rel="noreferrer">
                <img class="button-icon" src="../img/icons/github.svg" alt="" aria-hidden="true">
                <span>GitHub</span>
              </a>
            )}
          </div>
        </div>
        <aside class="project-summary" aria-label="Project details">
          {project.data.logo && (
            <img
              class="project-logo"
              src={`../${project.data.logo}`}
              alt={`${project.data.title} logo`}
            >
          )}
          {!project.data.logo && !project.data.tiles && (
            <div class="project-text-logo" aria-label={`${project.data.title} logo`}>
              {project.data.title}
            </div>
          )}
          {project.data.tiles && (
            <div class="project-tiles" aria-label={`${project.data.title} texture samples`}>
              {project.data.tiles.map((tile) => (
                <img src={`../${tile}`} alt="" loading="lazy">
              ))}
            </div>
          )}
          <dl class="detail-list">
            <div>
              <dt>Type</dt>
              <dd>{project.data.type}</dd>
            </div>
            <div>
              <dt>Status</dt>
              <dd>{project.data.status}</dd>
            </div>
            {startDate && (
              <div>
                <dt>Started</dt>
                <dd>{startDate}</dd>
              </div>
            )}
            <div>
              <dt>Stack</dt>
              <dd>{project.data.stack.join(", ")}</dd>
            </div>
          </dl>
        </aside>
      </div>
    </section>

    {
      sections.map((section, index) => (
        <section class={`section ${sectionClasses[index % sectionClasses.length]}`}>
          <div class="wrap project-body">
            <h2>{section.title}</h2>
            {
              section.blocks.map((block) => (
                block.type === "p" ? (
                  <p set:html={inlineMarkdown(block.text)} />
                ) : (
                  <ul>
                    {block.items.map((item) => <li set:html={inlineMarkdown(item)} />)}
                  </ul>
                )
              ))
            }
            {hasProcessionModelViewer && ["gallery", "models"].includes(section.title.toLowerCase()) && (
              <div
                class="block-gallery"
                  data-procession-model-viewer
                  data-source="../data/procession-blocks.json"
                  data-asset-prefix="../"
                >
                <div class="block-gallery-toolbar">
                  <div>
                    <span class="block-gallery-kicker">Models</span>
                    <strong data-block-name>Model viewer</strong>
                  </div>

                  <div class="block-picker-controls">
                    <label class="toggle-label">
                      <input type="checkbox" data-auto-rotate checked>
                      <span>Rotate</span>
                    </label>

                    <button class="block-picker-trigger" type="button" data-block-picker-trigger>
                      Models
                    </button>
                  </div>
                </div>

                <div class="block-picker-heading" data-block-picker-heading>Blocks</div>

                <canvas class="block-gallery-canvas" data-block-canvas aria-label="Interactive Procession model gallery"></canvas>

                <p class="block-gallery-fallback">
                  WebGL is unavailable in this browser.
                </p>
              </div>
            )}
          </div>
        </section>
      ))
    }

    {
      project.data.screenshot && (
        <section class="section project-media-section">
          <div class="wrap">
            <figure class="project-diagram project-screenshot">
              <img
                src={`../${project.data.screenshot}`}
                alt={`${project.data.title} screenshot`}
              >
              <figcaption>Project screenshot.</figcaption>
            </figure>
          </div>
        </section>
      )
    }

    {
      project.data.diagram && (
        <section class="section project-media-section">
          <div class="wrap">
          <figure class="project-diagram">
            <img
              src={`../${project.data.diagram}`}
              alt={`${project.data.title} project structure diagram`}
            >
            <figcaption>Current package structure and system boundaries.</figcaption>
          </figure>
          </div>
        </section>
      )
    }
  </main>
  {hasProcessionModelViewer && <script src="../js/procession-model-viewer.js" defer></script>}
</BaseLayout>
